{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "version": 2,
  "installCommand": "corepack enable && pnpm install --frozen-lockfile",
  "buildCommand": "BASE_PATH=/ pnpm --filter @workspace/mnk-logistics run build && node build-vercel-api.mjs",
  "outputDirectory": "artifacts/mnk-logistics/dist/public",
  "framework": null,
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api"
    },
    {
      "source": "/((?!api/).*)",
      "destination": "/index.html"
    }
  ]
}
