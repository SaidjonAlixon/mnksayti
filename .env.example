# =============================================================================
# MNK Logistics — Environment variables
# Copy to .env for local dev. On Vercel, set these in Project → Settings → Environment Variables.
# =============================================================================

# --- Telegram (driver application notifications) ---
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# --- Vercel Blob (required in production for file uploads) ---
# Create: Vercel Dashboard → Storage → Blob → Connect to project
# Vercel auto-injects BLOB_READ_WRITE_TOKEN when Blob is linked.
BLOB_READ_WRITE_TOKEN=

# --- API public URL (optional on Vercel — auto-detected from VERCEL_URL) ---
# Local:
API_PUBLIC_URL=http://localhost:24708
# Production example:
# API_PUBLIC_URL=https://your-domain.vercel.app

# --- Local development only ---
PORT=24708

# Frontend dev server (Terminal 2)
# PORT=24707
# BASE_PATH=/

# =============================================================================
# Vercel deployment checklist
# =============================================================================
# 1. Import repo in vercel.com → New Project
# 2. Framework Preset: Other (vercel.json handles build)
# 3. Root Directory: . (repository root)
# 4. Environment variables (Production + Preview):
#    - TELEGRAM_BOT_TOKEN
#    - TELEGRAM_CHAT_ID
#    - BLOB_READ_WRITE_TOKEN (or link Blob store in dashboard)
#    - API_PUBLIC_URL=https://your-production-domain.vercel.app
# 5. Optional: add custom domain in Vercel → Domains
# 6. Deploy — frontend at /, API at /api/*
#
# Note: Vercel serverless request body limit is ~4.5 MB per file on Hobby plan.
# Link Vercel Blob for durable storage (required on Vercel — local disk is not writable).
